# Version control
.git
.github
.gitignore

# Documentation
docs/
*.md

# Frontend build artifacts (the source itself is needed by the nginx
# production build — docker/nginx/Dockerfile.prod builds it from source)
frontend/node_modules/
frontend/dist/

# Backend — build artifacts and secrets never go into the image
backend/vendor/
backend/var/
backend/.env.local
backend/.env.*.local
backend/config/jwt/private.pem
backend/config/jwt/public.pem

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
