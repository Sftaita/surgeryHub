# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> redis ###
# Docker: overridden by docker-compose environment (redis://redis:6379)
# WAMP without Redis: comment the line below or set to empty to disable Redis cache
REDIS_URL=redis://localhost:6379
###< redis ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
DATABASE_URL="mysql://root:@127.0.0.1:3306/surgicalhub?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

APP_TIMEZONE=Europe/Brussels

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?:\/\/(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=3fcb5b44c838c0403ce83b89f1a5c6a9bec3ac36db874edd1519075a0465f83c
###< lexik/jwt-authentication-bundle ###

###> symfony/mailer ###
MAILER_DSN=smtp://127.0.0.1:1025
###< symfony/mailer ###

FRONTEND_URL=http://localhost:5173
MAILER_FROM_ADDRESS=no-reply@surgicalhub.local
MAILER_FROM_NAME=SurgicalHub

###> app/mail-safe-mode ###
# Last-resort guard (App\EventListener\MailSafeModeListener) blocking any outgoing email
# to a recipient that isn't explicitly allow-listed, everywhere except real production.
# See docs/mail-safe-mode.md for the full explanation and how to use it.
#
#   auto (default) — safe mode ON unless kernel.environment === 'prod'. No action needed
#                     for the normal case: every non-prod environment is safe by default.
#   on / 1         — force safe mode ON, even in prod (e.g. for a controlled manual test
#                     session against real production — see docs/mail-safe-mode.md).
#   off / 0        — force safe mode OFF, even outside prod. Only for a genuine staging
#                     environment that must send real mail — never set this casually.
MAIL_SAFE_MODE=auto
MAIL_SAFE_ALLOWED_DOMAINS=surgicalhub.internal
MAIL_SAFE_ALLOWED_RECIPIENTS=
#
# When safe mode is active, MAIL_SAFE_DELIVERY_MODE picks HOW it protects real people:
#   auto (default) — "capture" if MAILER_DSN is a verified local sink (see
#                     MAIL_SAFE_LOCAL_SINKS below), "allowlist" otherwise. This is what
#                     gives local dev/test + Mailpit a zero-config capture mode (real
#                     recipients untouched, visible in Mailpit) while staying safe by
#                     default anywhere a real SMTP relay is configured.
#   capture        — force capture mode. REFUSED (falls back to allowlist, logged as
#                     critical) if MAILER_DSN does not match MAIL_SAFE_LOCAL_SINKS — a
#                     misconfigured MAILER_DSN can never accidentally disable filtering.
#   allowlist      — force the pre-2026-07-12 filtering behavior regardless of transport
#                     (e.g. staging with a real, potentially-external SMTP relay).
MAIL_SAFE_DELIVERY_MODE=auto
# host:port pairs recognized as local, non-delivering capture sinks (Mailpit/MailHog-
# style). Comma-separated. Symfony Mailer's built-in null:// transport is always
# recognized too, regardless of this list.
MAIL_SAFE_LOCAL_SINKS=mailer:1025,localhost:1025,127.0.0.1:1025
###< app/mail-safe-mode ###
