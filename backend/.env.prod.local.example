# =============================================================================
# SurgicalHub — backend/.env.prod.local (PRODUCTION SECRETS — NEVER COMMIT)
# =============================================================================
#
# Copy this file to `.env.prod.local` on the production server only:
#
#   cp .env.prod.local.example .env.prod.local
#   nano .env.prod.local   # fill in real values below
#
# `.env.prod.local` is already covered by .gitignore (`/.env.*.local`).
# It must NEVER be committed, emailed, or stored in the repo.
#
# Symfony loads, in order (last wins): .env -> .env.local -> .env.prod
# -> .env.prod.local -> real environment variables.
# Everything below OVERRIDES the dev defaults from `.env` for APP_ENV=prod.
# =============================================================================

###> symfony/framework-bundle ###
APP_ENV=prod
APP_DEBUG=0
# Generate with: php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=CHANGE_ME_GENERATE_32_HEX_CHARS
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Used to generate absolute URLs from CLI/console (emails, messenger workers, etc.)
DEFAULT_URI=https://api.surgicalhub.be
###< symfony/routing ###

###> symfony/messenger ###
# Doctrine transport (DB table `messenger_messages`) — no Redis/RabbitMQ needed.
# Consumed via a Hostinger Cron Job (see docs/production-hostinger.md).
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> doctrine/doctrine-bundle ###
# Hostinger hPanel > Databases > MySQL Databases: create DB + dedicated user.
# Hostinger MySQL host is usually "localhost" when PHP and DB are on the same
# Cloud Startup instance. Adjust serverVersion to the version shown in hPanel.
DATABASE_URL="mysql://HOSTINGER_DB_USER:HOSTINGER_DB_PASSWORD@localhost:3306/HOSTINGER_DB_NAME?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

APP_TIMEZONE=Europe/Brussels

###> nelmio/cors-bundle ###
# Only the production frontend origin(s) may call the API.
# origin_regex is enabled in nelmio_cors.yaml, so this is a regex.
# Add "|https://www\.surgicalhub\.be" if you also serve a www. alias.
CORS_ALLOW_ORIGIN='^https://surgicalhub\.be$'
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
# Generate a DEDICATED prod keypair on the server (never reuse the dev one):
#   php bin/console lexik:jwt:generate-keypair --env=prod --overwrite
# Then set the SAME passphrase you typed during generation below.
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=CHANGE_ME_USE_A_LONG_RANDOM_PASSPHRASE
###< lexik/jwt-authentication-bundle ###

###> symfony/mailer ###
# Hostinger SMTP (hPanel > Emails) or a transactional provider (Brevo, Mailgun...)
MAILER_DSN=smtp://USER:PASSWORD@smtp.hostinger.com:587?encryption=tls
###< symfony/mailer ###

FRONTEND_URL=https://surgicalhub.be
MAILER_FROM_ADDRESS=no-reply@surgicalhub.be
MAILER_FROM_NAME=SurgicalHub

###> app/mail-safe-mode ###
# Do NOT set MAIL_SAFE_MODE here for normal operation — leave it unset/inherited from
# the committed .env default ("auto"), which correctly resolves to OFF in prod
# (kernel.environment === 'prod'), so real emails go out normally.
#
# To run a manual functional test directly against production WITHOUT risking a real
# send (see docs/mail-safe-mode.md and the 2026-07-12 incident in docs/production.md):
# add "MAIL_SAFE_MODE=on" to this file, then `docker compose up -d` (recreates php +
# worker with the new env — a plain `docker restart` does NOT reread this file), run
# the test, then remove the line and `docker compose up -d` again. It must cover both
# php (HTTP-triggered sends) and worker (the actual async delivery) — a one-off
# `docker exec -e MAIL_SAFE_MODE=on ... php bin/console` only affects that single
# process, not the running php-fpm/worker handling the real request/queue.
###< app/mail-safe-mode ###

###> sentry/sentry-symfony ###
# Use a DEDICATED prod Sentry project/DSN (do not reuse the dev DSN committed
# in .env — rotate that one, see docs/production-hostinger.md security notes).
# Leave empty to disable Sentry entirely.
SENTRY_DSN=""
###< sentry/sentry-symfony ###

###> web-push (VAPID) ###
# Generate a DEDICATED prod keypair:
#   php bin/console app:vapid:generate   (or via web-push-php CLI)
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_SUBJECT=mailto:admin@surgicalhub.be
###< web-push (VAPID) ###

###> redis (optional) ###
# Not required: cache.yaml defaults to the filesystem adapter in prod.
# Only set this if Hostinger Redis becomes available later (see Plan B).
#REDIS_URL=redis://127.0.0.1:6379
###< redis (optional) ###
