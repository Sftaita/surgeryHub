<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>SurgicalHub — Absence</title>
<!--[if mso]>
<style>table{border-collapse:collapse;} div,td{font-family:Arial,sans-serif;}</style>
<noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript>
<![endif]-->
<style>
  @media (max-width:620px){
    .sh-container{width:100% !important;}
    .sh-pad{padding-left:20px !important;padding-right:20px !important;}
  }
</style>
</head>
{% set count = missions|length %}

{% macro missionCard(m) %}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border:1px solid #E7EBEF;border-left:4px solid #F0A91B;border-radius:10px;margin-bottom:10px;">
<tr><td style="padding:16px 18px;">
<div style="font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:15px;font-weight:700;color:#16202B;">{{ m.date }} · {{ m.moment }}{% if m.horaire %} · {{ m.horaire }}{% endif %}</div>
{% if m.siteName %}
<div style="margin-top:8px;">
<span style="display:inline-block;background-color:#F1F4F7;color:#566270;font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:12px;font-weight:600;padding:4px 10px;border-radius:100px;">{{ m.siteName }}</span>
</div>
{% endif %}
<div style="margin-top:8px;padding-top:8px;border-top:1px solid #F1F4F7;font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:14px;color:#3A4754;">
Instrumentiste : <span style="color:#98A2AE;">{{ m.instrumentistName ?: 'Aucun' }}</span> <span style="color:#C2C9D1;">→</span> <span style="font-weight:700;color:#B7791F;">À pourvoir</span>
</div>
</td></tr>
</table>
{% endmacro %}
{% import _self as m %}

<body style="margin:0;padding:0;background-color:#F5F7FA;-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%;">
<div style="display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#F5F7FA;">{{ recipientName }}, {{ count }} {{ count > 1 ? 'de vos missions sont' : 'de vos missions est' }} désormais à pourvoir suite à une absence instrumentiste.</div>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#F5F7FA;">
<tr><td align="center" style="padding:40px 16px;">
<table role="presentation" width="600" cellpadding="0" cellspacing="0" class="sh-container" style="width:600px;max-width:600px;background-color:#FFFFFF;border-radius:12px;border:1px solid #E7EBEF;">

<!-- Header -->
<tr><td class="sh-pad" style="padding:26px 32px;border-bottom:1px solid #E7EBEF;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
<td style="font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:18px;font-weight:800;color:#144D38;letter-spacing:-0.2px;">
<span style="display:inline-block;width:9px;height:9px;border-radius:3px;background-color:#42A882;margin-right:9px;"></span><span>SurgicalHub</span>
</td>
<td align="right" style="font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:11px;font-weight:700;letter-spacing:0.6px;text-transform:uppercase;color:#727E8C;">Absence</td>
</tr></table>
</td></tr>

<!-- Title -->
<tr><td class="sh-pad" style="padding:28px 32px 20px 32px;">
<div style="font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:23px;font-weight:800;color:#16202B;line-height:1.3;">{{ count > 1 ? 'Missions désormais à pourvoir' : 'Mission désormais à pourvoir' }}</div>
</td></tr>

<!-- Greeting -->
<tr><td class="sh-pad" style="padding:0 32px 22px 32px;font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:15px;line-height:1.65;color:#3A4754;">
Bonjour {{ recipientName }},<br><br>
L'instrumentiste précédemment affecté à {{ count > 1 ? 'ces interventions' : 'cette intervention' }} a déclaré une absence. {{ count > 1 ? 'Ces missions sont' : 'Cette mission est' }} désormais à pourvoir et {{ count > 1 ? 'ont' : 'a' }} été remise{{ count > 1 ? 's' : '' }} en pool — elle{{ count > 1 ? 's' : '' }} sera{{ count > 1 ? 'nt' : '' }} proposée{{ count > 1 ? 's' : '' }} aux instrumentistes éligibles via SurgicalHub.
</td></tr>

<!-- Missions -->
<tr><td class="sh-pad" style="padding:0 32px 4px 32px;">
{% for mission in missions %}
  {{ m.missionCard(mission) }}
{% endfor %}
</td></tr>

<!-- Footer -->
<tr><td class="sh-pad" style="padding:28px 32px 30px 32px;">
<div style="border-top:1px solid #E7EBEF;padding-top:20px;font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:12px;color:#98A2AE;line-height:1.7;">
SurgicalHub — document confidentiel, destiné uniquement à {{ recipientName }}.<br>
Cet e-mail est généré automatiquement, merci de ne pas y répondre.
</div>
</td></tr>

</table>
</td></tr>
</table>
</body>
</html>
