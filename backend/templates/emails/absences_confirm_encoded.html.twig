<!DOCTYPE html>
<html lang="fr">
<head><meta charset="UTF-8"><style>
body { font-family: Arial, sans-serif; color: #333; font-size: 14px; line-height: 1.6; }
.container { max-width: 600px; margin: 0 auto; padding: 24px; }
.header { border-bottom: 2px solid #1B5FD0; padding-bottom: 12px; margin-bottom: 20px; }
.title { color: #1B5FD0; font-size: 18px; font-weight: bold; }
ul { margin: 8px 0 0 0; padding-left: 18px; font-size: 13px; }
.footer { margin-top: 32px; font-size: 12px; color: #888; border-top: 1px solid #eee; padding-top: 12px; }
</style></head>
<body>
<div class="container">
  <div class="header">
    <div class="title">SurgicalHub — Récapitulatif de vos congés encodés</div>
  </div>

  <p>{{ greeting }},</p>

  <p style="white-space: pre-line;">{{ message }}</p>

  <ul>
    {% for absence in absences %}
    <li>
      {% if absence.dateStart == absence.dateEnd %}
        {{ absence.dateStart|date('d/m/Y') }}
      {% else %}
        {{ absence.dateStart|date('d/m/Y') }} → {{ absence.dateEnd|date('d/m/Y') }}
      {% endif %}
      {% if absence.reason %} — {{ absence.reason }}{% endif %}
    </li>
    {% endfor %}
  </ul>

  <div class="footer">SurgicalHub — document confidentiel</div>
</div>
</body>
</html>
