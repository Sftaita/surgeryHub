<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>SurgicalHub — Récapitulatif planning</title>
<!--[if mso]>
<style>table{border-collapse:collapse;} div,td{font-family:Arial,sans-serif;}</style>
<noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript>
<![endif]-->
<style>
  @media (max-width:620px){
    .sh-container{width:100% !important;}
    .sh-pad{padding-left:20px !important;padding-right:20px !important;}
  }
</style>
</head>
{% set recipientName = instrumentist.firstname ?: instrumentist.email %}
{% set recipientFullName = (instrumentist.firstname ~ ' ' ~ instrumentist.lastname)|trim ?: instrumentist.email %}
{% set changeCount = (added|length) + (modified|length) + (removed|length) %}

{% macro momentLabel(period) %}{{ period == 'AM' ? 'Matin' : 'Après-midi' }}{% endmacro %}

{% macro card(dateLabel, momentLabel, surgeonName, siteName, lines) %}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border:1px solid #E7EBEF;border-left:4px solid #F0A91B;border-radius:10px;margin-bottom:10px;">
<tr><td style="padding:16px 18px;">
<div style="font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:15px;font-weight:700;color:#16202B;">{{ dateLabel }} · {{ momentLabel }}</div>
{% if surgeonName %}<div style="font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:14px;color:#3A4754;margin-top:3px;">{{ surgeonName }}</div>{% endif %}
{% if siteName %}
<div style="margin-top:8px;">
<span style="display:inline-block;background-color:#EFFAF5;color:#1F6B4F;font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:12px;font-weight:600;padding:4px 10px;border-radius:100px;">{{ siteName }}</span>
</div>
{% endif %}
{% for line in lines %}
<div style="margin-top:{{ loop.first ? 12 : 6 }}px;{% if loop.first %}padding-top:12px;border-top:1px solid #F1F4F7;{% endif %}font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:14px;color:#3A4754;">{{ line|raw }}</div>
{% endfor %}
</td></tr>
</table>
{% endmacro %}

{% macro changeLine(label, before, after) %}{{ label }} : <span style="color:#98A2AE;">{{ before ?: 'Aucun' }}</span> <span style="color:#C2C9D1;">→</span> <span style="font-weight:700;color:#144D38;">{{ after ?: 'Aucun' }}</span>{% endmacro %}
{% import _self as m %}

<body style="margin:0;padding:0;background-color:#F5F7FA;-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%;">
<div style="display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#F5F7FA;">{{ recipientName }}, {{ changeCount }} modification{{ changeCount > 1 ? 's' : '' }} vous concerne{{ changeCount > 1 ? 'nt' : '' }} sur votre planning du {{ periodFrom|date('d') }} au {{ periodTo|date('d') }} {{ periodTo|french_month_short }} {{ periodTo|date('Y') }}.</div>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#F5F7FA;">
<tr><td align="center" style="padding:40px 16px;">
<table role="presentation" width="600" cellpadding="0" cellspacing="0" class="sh-container" style="width:600px;max-width:600px;background-color:#FFFFFF;border-radius:12px;border:1px solid #E7EBEF;">

<!-- Header -->
<tr><td class="sh-pad" style="padding:26px 32px;border-bottom:1px solid #E7EBEF;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
<td style="font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:18px;font-weight:800;color:#144D38;letter-spacing:-0.2px;">
<span style="display:inline-block;width:9px;height:9px;border-radius:3px;background-color:#42A882;margin-right:9px;"></span><span>SurgicalHub</span>
</td>
<td align="right" style="font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:11px;font-weight:700;letter-spacing:0.6px;text-transform:uppercase;color:#727E8C;">Planning</td>
</tr></table>
</td></tr>

<!-- Title -->
<tr><td class="sh-pad" style="padding:28px 32px 6px 32px;">
<div style="font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:23px;font-weight:800;color:#16202B;line-height:1.3;">Récapitulatif de votre planning</div>
</td></tr>
<tr><td class="sh-pad" style="padding:0 32px 20px 32px;">
<span style="display:inline-block;background-color:#EDF4FF;color:#1B5FD0;font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:13px;font-weight:700;padding:6px 13px;border-radius:100px;">{{ periodFrom|date('d') }} → {{ periodTo|date('d') }} {{ periodTo|french_month_short }} {{ periodTo|date('Y') }}</span>
</td></tr>

<!-- Greeting -->
<tr><td class="sh-pad" style="padding:0 32px 4px 32px;font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:15px;line-height:1.65;color:#3A4754;">
Bonjour {{ recipientName }},<br><br>
Voici les modifications du planning qui vous concernent pour cette période.
</td></tr>

{% if changeCount > 0 %}
<!-- Modifications -->
<tr><td class="sh-pad" style="padding:22px 32px 10px 32px;">
<table role="presentation" cellpadding="0" cellspacing="0"><tr>
<td style="font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:13px;font-weight:700;letter-spacing:0.2px;color:#B7791F;">
<span style="display:inline-block;width:7px;height:7px;border-radius:2px;background-color:#F0A91B;margin-right:8px;"></span>Modifications ({{ changeCount }})
</td>
</tr></table>
</td></tr>
<tr><td class="sh-pad" style="padding:0 32px 4px 32px;">
{% for entry in added %}
  {{ m.card(entry.date|date('d/m/Y'), m.momentLabel(entry.period), entry.surgeonName, entry.siteName, [m.changeLine('Instrumentiste', 'Aucun', entry.instrumentistName)]) }}
{% endfor %}
{% for entry in modified %}
  {% set lines = [] %}
  {% if entry.changes.schedule is defined %}
    {% set lines = lines|merge([m.changeLine('Horaire', entry.changes.schedule.from.startAt ~ '–' ~ entry.changes.schedule.from.endAt, entry.changes.schedule.to.startAt ~ '–' ~ entry.changes.schedule.to.endAt)]) %}
  {% endif %}
  {% if entry.changes.instrumentist is defined %}
    {% set lines = lines|merge([m.changeLine('Instrumentiste', entry.changes.instrumentist.from ? entry.changes.instrumentist.from.name : null, entry.changes.instrumentist.to ? entry.changes.instrumentist.to.name : null)]) %}
  {% endif %}
  {{ m.card(entry.mission.date|date('d/m/Y'), m.momentLabel(entry.mission.period), entry.mission.surgeonName, entry.mission.siteName, lines) }}
{% endfor %}
{% for entry in removed %}
  {{ m.card(entry.date|date('d/m/Y'), m.momentLabel(entry.period), entry.surgeonName, entry.siteName, [m.changeLine('Statut', 'Assignée', 'Annulée')]) }}
{% endfor %}
</td></tr>
{% else %}
<!-- No modifications -->
<tr><td class="sh-pad" style="padding:22px 32px 4px 32px;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#EFFAF5;border:1px solid #DDF4EA;border-left:4px solid #42A882;border-radius:10px;">
<tr><td style="padding:16px 18px;font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:14px;color:#144D38;">
<span style="font-weight:700;">Aucune modification</span> sur cette période — votre planning reste inchangé.
</td></tr>
</table>
</td></tr>
{% endif %}

<!-- Attachment -->
<tr><td class="sh-pad" style="padding:22px 32px 4px 32px;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#F1F4F7;border-radius:10px;"><tr>
<td style="width:1%;white-space:nowrap;padding:12px 0 12px 14px;">
<span style="display:inline-block;background-color:#DDE2E8;color:#566270;font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:10px;font-weight:800;letter-spacing:0.3px;padding:5px 8px;border-radius:6px;">PDF</span>
</td>
<td style="padding:12px 14px 12px 10px;font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:13px;color:#3A4754;">Planning complet — {{ periodFrom|date('d/m') }} au {{ periodTo|date('d/m/Y') }}, en pièce jointe.</td>
</tr></table>
</td></tr>

<!-- Footer -->
<tr><td class="sh-pad" style="padding:28px 32px 30px 32px;">
<div style="border-top:1px solid #E7EBEF;padding-top:20px;font-family:Inter,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:12px;color:#98A2AE;line-height:1.7;">
SurgicalHub — document confidentiel, destiné uniquement à {{ recipientFullName }}.<br>
Cet e-mail est généré automatiquement, merci de ne pas y répondre.
</div>
</td></tr>

</table>
</td></tr>
</table>
</body>
</html>
