<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: DejaVu Sans, sans-serif; font-size: 11px; color: #1a1a1a; }
  .page { padding: 32px 40px; }
  .header { display: table; width: 100%; margin-bottom: 28px; border-bottom: 2px solid #2e7d32; padding-bottom: 16px; }
  .header-left { display: table-cell; vertical-align: top; }
  .header-right { display: table-cell; text-align: right; vertical-align: top; }
  .logo { font-size: 20px; font-weight: bold; color: #2e7d32; letter-spacing: 1px; }
  .doc-title { font-size: 22px; font-weight: bold; color: #2e7d32; margin-bottom: 4px; }
  .doc-sub { font-size: 13px; color: #555; }
  .meta-grid { display: table; width: 100%; margin-bottom: 24px; }
  .meta-col { display: table-cell; width: 50%; vertical-align: top; padding: 12px 16px; background: #f1f8f2; }
  .meta-col + .meta-col { background: none; padding-left: 24px; }
  .meta-label { font-size: 9px; text-transform: uppercase; color: #888; letter-spacing: 0.5px; margin-bottom: 2px; }
  .meta-value { font-size: 12px; color: #1a1a1a; font-weight: bold; }
  .section-title { font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; color: #2e7d32; margin-bottom: 6px; margin-top: 18px; border-bottom: 1px solid #c8e6c9; padding-bottom: 3px; }
  table { width: 100%; border-collapse: collapse; margin-bottom: 8px; }
  thead th { background: #2e7d32; color: #fff; padding: 7px 10px; text-align: left; font-size: 10px; font-weight: bold; }
  tbody tr:nth-child(even) { background: #f1f8f2; }
  tbody td { padding: 7px 10px; border-bottom: 1px solid #c8e6c9; font-size: 10px; }
  .badge-block { display: inline-block; padding: 1px 6px; background: #c8e6c9; color: #1b5e20; font-size: 9px; font-weight: bold; }
  .badge-consultation { display: inline-block; padding: 1px 6px; background: #dcedc8; color: #33691e; font-size: 9px; font-weight: bold; }
  .no-data { color: #999; font-style: italic; font-size: 10px; padding: 8px 0; }
  .footer { margin-top: 32px; border-top: 1px solid #c8e6c9; padding-top: 10px; font-size: 9px; color: #888; text-align: right; }
</style>
</head>
<body>
<div class="page">
  <div class="header">
    <div class="header-left">
      <div class="logo">SurgicalHub</div>
    </div>
    <div class="header-right">
      <div class="doc-title">Planning Instrumentiste</div>
      <div class="doc-sub">Généré le {{ "now"|date("d/m/Y") }}</div>
    </div>
  </div>

  <div class="meta-grid">
    <div class="meta-col">
      <div class="meta-label">Instrumentiste</div>
      <div class="meta-value">
        {% set name = (instrumentist.firstname ~ ' ' ~ instrumentist.lastname)|trim %}
        {{ name != '' ? name : instrumentist.email }}
      </div>
      <div style="font-size:10px; color:#555; margin-top:2px;">{{ instrumentist.email }}</div>
    </div>
    <div class="meta-col">
      <div class="meta-label">Période</div>
      <div class="meta-value">{{ periodFrom|date("d/m/Y") }} — {{ periodTo|date("d/m/Y") }}</div>
    </div>
  </div>

  {% set missionsByDay = {} %}
  {% for mission in missions %}
    {% set day = mission.startAt|date("Y-m-d") %}
    {% if missionsByDay[day] is not defined %}
      {% set missionsByDay = missionsByDay|merge({(day): []}) %}
    {% endif %}
    {% set missionsByDay = missionsByDay|merge({(day): missionsByDay[day]|merge([mission])}) %}
  {% endfor %}

  {% for day, dayMissions in missionsByDay %}
    <div class="section-title">{{ day|french_day }} {{ day|date("d/m/Y") }}</div>
    <table>
      <thead>
        <tr>
          <th>Heure début</th>
          <th>Heure fin</th>
          <th>Type</th>
          <th>Chirurgien</th>
          <th>Site</th>
          <th>Statut</th>
        </tr>
      </thead>
      <tbody>
        {% for mission in dayMissions %}
        <tr>
          <td>{{ mission.startAt|date("H:i") }}</td>
          <td>{{ mission.endAt|date("H:i") }}</td>
          <td>
            {% if mission.type.value == 'BLOCK' %}
              <span class="badge-block">Bloc</span>
            {% else %}
              <span class="badge-consultation">Consultation</span>
            {% endif %}
          </td>
          <td>
            {% set surgeonName = (mission.surgeon.firstname ~ ' ' ~ mission.surgeon.lastname)|trim %}
            {{ surgeonName != '' ? surgeonName : mission.surgeon.email }}
          </td>
          <td>{{ mission.site ? mission.site.name : '—' }}</td>
          <td>{{ mission.status.label }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <div class="no-data">Aucune mission planifiée pour cette période.</div>
  {% endfor %}

  <div class="footer">SurgicalHub — Document généré automatiquement</div>
</div>
</body>
</html>
