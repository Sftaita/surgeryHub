<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: DejaVu Sans, sans-serif; font-size: 11px; color: #1a1a1a; }
  .page { padding: 32px 40px; }
  .header { display: table; width: 100%; margin-bottom: 28px; border-bottom: 2px solid #1565c0; padding-bottom: 16px; }
  .header-left { display: table-cell; vertical-align: top; }
  .header-right { display: table-cell; text-align: right; vertical-align: top; }
  .logo { font-size: 20px; font-weight: bold; color: #1565c0; letter-spacing: 1px; }
  .doc-title { font-size: 22px; font-weight: bold; color: #1565c0; margin-bottom: 4px; }
  .doc-sub { font-size: 13px; color: #555; }
  .meta-grid { display: table; width: 100%; margin-bottom: 24px; }
  .meta-col { display: table-cell; width: 50%; vertical-align: top; padding: 12px 16px; background: #e3f2fd; }
  .meta-col + .meta-col { background: none; padding-left: 24px; }
  .meta-label { font-size: 9px; text-transform: uppercase; color: #888; letter-spacing: 0.5px; margin-bottom: 2px; }
  .meta-value { font-size: 12px; color: #1a1a1a; font-weight: bold; }
  table { width: 100%; border-collapse: collapse; margin-bottom: 8px; }
  thead th { background: #1565c0; color: #fff; padding: 7px 10px; text-align: left; font-size: 10px; font-weight: bold; }
  tbody tr:nth-child(even) { background: #e3f2fd; }
  tbody td { padding: 7px 10px; border-bottom: 1px solid #bbdefb; font-size: 10px; }
  .badge-block { display: inline-block; padding: 1px 6px; background: #bbdefb; color: #0d47a1; font-size: 9px; font-weight: bold; }
  .badge-consultation { display: inline-block; padding: 1px 6px; background: #e1f5fe; color: #01579b; font-size: 9px; font-weight: bold; }
  .to-confirm { color: #e65100; font-style: italic; }
  .no-data { color: #999; font-style: italic; font-size: 10px; padding: 8px 0; }
  .footer { margin-top: 32px; border-top: 1px solid #bbdefb; padding-top: 10px; font-size: 9px; color: #888; text-align: right; }
</style>
</head>
<body>
<div class="page">
  <div class="header">
    <div class="header-left">
      <div class="logo">SurgicalHub</div>
    </div>
    <div class="header-right">
      <div class="doc-title">Planning Chirurgien</div>
      <div class="doc-sub">Généré le {{ "now"|date("d/m/Y") }}</div>
    </div>
  </div>

  <div class="meta-grid">
    <div class="meta-col">
      <div class="meta-label">Chirurgien</div>
      <div class="meta-value">
        {% set name = (surgeon.firstname ~ ' ' ~ surgeon.lastname)|trim %}
        {{ name != '' ? name : surgeon.email }}
      </div>
      <div style="font-size:10px; color:#555; margin-top:2px;">{{ surgeon.email }}</div>
    </div>
    <div class="meta-col">
      <div class="meta-label">Période</div>
      <div class="meta-value">{{ periodFrom|date("d/m/Y") }} — {{ periodTo|date("d/m/Y") }}</div>
    </div>
  </div>

  {% set sortedMissions = missions|sort((a, b) => a.startAt <=> b.startAt) %}

  {% if sortedMissions|length > 0 %}
  <table>
    <thead>
      <tr>
        <th>Date</th>
        <th>Horaire</th>
        <th>Type</th>
        <th>Instrumentation</th>
      </tr>
    </thead>
    <tbody>
      {% for mission in sortedMissions %}
      <tr>
        <td>{{ mission.startAt|date("d/m/Y") }}</td>
        <td>{{ mission.startAt|date("H:i") }}–{{ mission.endAt|date("H:i") }}</td>
        <td>
          {% if mission.type.value == 'BLOCK' %}
            <span class="badge-block">Bloc</span>
          {% else %}
            <span class="badge-consultation">Consultation</span>
          {% endif %}
        </td>
        <td>
          {% if mission.instrumentist %}
            {% set instrName = (mission.instrumentist.firstname ~ ' ' ~ mission.instrumentist.lastname)|trim %}
            {{ instrName != '' ? instrName : mission.instrumentist.email }}
          {% else %}
            <span class="to-confirm">Instrumentiste non attribuée</span>
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div class="no-data">Aucune mission planifiée pour cette période.</div>
  {% endif %}

  <div class="footer">SurgicalHub — Document généré automatiquement</div>
</div>
</body>
</html>
